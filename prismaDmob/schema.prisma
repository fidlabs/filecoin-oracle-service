generator client {
  provider        = "prisma-client-js"
  output          = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

model unified_verified_deal {
  id         Int      @id(map: "PK_76f56333d366aa67ac747861bde") @default(autoincrement())
  type       String?  @db.VarChar
  clientId   String?  @db.VarChar
  providerId String?  @db.VarChar
  sectorId   String?  @db.VarChar
  pieceCid   String?  @db.VarChar
  pieceSize  Decimal? @db.Decimal
  termMax    Int?
  termMin    Int?
  termStart  Int?
  dealId     Int      @default(0)
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  updatedAt  DateTime @default(now()) @db.Timestamp(6)
  claimId    Int      @default(0)

  @@index([clientId], map: "unified_verified_deal_clientid_index")
  @@index([clientId, providerId, pieceCid, sectorId], map: "unified_verified_deal_composed_index")
  @@index([dealId], map: "unified_verified_deal_dealid_index")
  @@index([providerId], map: "unified_verified_deal_providerid_index")
}
