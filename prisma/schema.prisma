// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum SectorStatus {
  Dead
  Active
  Faulty
}

enum DealState {
  None
  Proposed
  Accepted
  Active
  Finalized
  Rejected
  Expired
  Terminated
}

enum ContractName {
  PoRepMarket
  Client
  SliOracle
  SliScorer
  SpRegistry
  Validator
  FilecoinPay
}

model porep_market_deal_history {
  id                String            @id @default(uuid()) @db.Uuid
  porepMarketDealId String            @db.Uuid
  state             DealState
  createdAt         DateTime          @default(now())
  deal              porep_market_deal @relation(fields: [porepMarketDealId], references: [id])

  @@index([porepMarketDealId])
}

model porep_market_deal_requirement {
  id                      String            @id @default(uuid()) @db.Uuid
  porepMarketDealId       String            @unique @db.Uuid
  onChainDealId           BigInt            @unique // external deal ID - from chain
  retrievabilityBps       BigInt
  bandwidthBytesPerSecond BigInt
  latencyMs               BigInt
  indexingPct             BigInt
  deal                    porep_market_deal @relation(fields: [porepMarketDealId], references: [id])
  createdAt               DateTime          @default(now())
  updatedAt               DateTime          @updatedAt

  @@index([porepMarketDealId])
}

model porep_market_deal_terms {
  id                 String            @id @default(uuid()) @db.Uuid
  porepMarketDealId  String            @unique @db.Uuid
  onChainDealId      BigInt            @unique // external deal ID - from chain
  requestedSizeBytes BigInt
  durationEpochs     BigInt
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  deal               porep_market_deal @relation(fields: [porepMarketDealId], references: [id])
}

model porep_market_deal_payment {
  id                    String            @id @default(uuid()) @db.Uuid
  porepMarketDealId     String            @unique @db.Uuid
  onChainDealId         BigInt            @unique // external deal ID - from chain
  paymentToken          String
  pricePer32GiBPerMonth BigInt
  billed32GiBUnits      BigInt
  railMaxRatePerEpoch   BigInt
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt
  deal                  porep_market_deal @relation(fields: [porepMarketDealId], references: [id])

  @@index([porepMarketDealId])
}

model porep_market_deal_evidence_status {
  id                       String            @id @default(uuid()) @db.Uuid
  porepMarketDealId        String            @unique @db.Uuid
  onChainDealId            BigInt            @unique // external deal ID - from chain
  activeCoveredBytes       BigInt
  lastEvidenceRefreshEpoch BigInt
  reasonCode               BigInt
  result                   BigInt
  createdAt                DateTime          @default(now())
  updatedAt                DateTime          @updatedAt
  deal                     porep_market_deal @relation(fields: [porepMarketDealId], references: [id])

  @@index([porepMarketDealId])
}

model porep_market_deal_claim {
  id                String        @id @default(uuid()) @db.Uuid
  porepMarketDealId String        @db.Uuid
  claimId           BigInt
  sector            BigInt
  provider          BigInt
  client            BigInt
  data              String
  size              BigInt
  term_min          BigInt
  term_max          BigInt
  term_start        BigInt
  status            SectorStatus?

  deal porep_market_deal @relation(fields: [porepMarketDealId], references: [id])

  @@unique([claimId, sector, provider])
  @@index([porepMarketDealId])
}

model porep_market_deal {
  id                             String                                   @id @default(uuid()) @db.Uuid
  onChainDealId                  BigInt                                   @unique // external deal ID - from chain
  client                         String
  provider                       BigInt
  offerId                        BigInt?
  railId                         BigInt
  evidenceAdapterContractAddress String
  validatorContractAddress       String
  providerOrganization           String?
  state                          DealState
  terms                          porep_market_deal_terms?
  payment                        porep_market_deal_payment?
  requiredSLIs                   porep_market_deal_requirement?
  evidenceStatus                 porep_market_deal_evidence_status?
  manifestHash                   String?
  manifestLocation               String?
  expiresAtEpoch                 BigInt?
  serviceStartEpoch              BigInt?
  serviceEndEpoch                BigInt?
  reservedBytes                  BigInt?
  committedBytes                 BigInt?
  allocationsRequiredCount       BigInt?
  allocationsMatchedCount        BigInt?
  isAllocationsMatched           Boolean
  isRailTerminated               Boolean
  dealStartEpoch                 BigInt?
  dealEndEpoch                   BigInt?
  allocationIds                  BigInt[]
  claims                         porep_market_deal_claim[]
  history                        porep_market_deal_history[]
  settlement_history             porep_market_deal_settlement_history[]
  transactions                   porep_market_deal_on_chain_transaction[]
  score                          porep_market_deal_score[]
  proposedAtEpoch                BigInt
  activatePaymentAt              DateTime?
  urlFinderSliTargetTriggeredAt  DateTime?
  lastSyncedAt                   DateTime                                 @updatedAt
  createdAt                      DateTime                                 @default(now())
  updatedAt                      DateTime                                 @updatedAt

  @@index([onChainDealId])
  @@index([state])
  @@index([provider])
}

model porep_market_deal_settlement_history {
  id                String            @id @default(uuid()) @db.Uuid
  porepMarketDealId String            @db.Uuid
  epoch             BigInt
  settlementAt      DateTime          @default(now())
  deal              porep_market_deal @relation(fields: [porepMarketDealId], references: [id])

  @@index([porepMarketDealId])
}

model porep_market_deal_score {
  id                       String            @id @default(uuid()) @db.Uuid
  porepMarketDealId        String            @db.Uuid
  calculatedScore          BigInt
  averageRetrievabilityBps BigInt
  averageBandwidthMbps     BigInt
  averageLatencyMs         BigInt
  averageIndexingPct       BigInt
  deal                     porep_market_deal @relation(fields: [porepMarketDealId], references: [id])
  createdAt                DateTime          @default(now())
}

model porep_market_deal_on_chain_transaction {
  id                String                                         @id @default(uuid()) @db.Uuid
  porepMarketDealId String                                         @db.Uuid
  contractName      ContractName
  functionName      String
  createdAt         DateTime                                       @default(now())
  deal              porep_market_deal                              @relation(fields: [porepMarketDealId], references: [id])
  detail            porep_market_deal_on_chain_transaction_detail?

  @@index([porepMarketDealId])
}

model porep_market_deal_on_chain_transaction_detail {
  id              String                                 @id @default(uuid()) @db.Uuid
  transactionId   String                                 @unique @db.Uuid
  transactionHash String
  blockNumber     BigInt
  gasUsed         BigInt?
  gasPrice        BigInt?
  nonce           BigInt?
  fromAddress     String?
  toAddress       String?
  value           BigInt?
  inputData       String?
  createdAt       DateTime                               @default(now())
  transaction     porep_market_deal_on_chain_transaction @relation(fields: [transactionId], references: [id])
}
