// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "./generated/client"
}

datasource db {
  provider = "postgresql"
}

enum DealState {
  Proposed
  Accepted
  Completed
  Rejected
  Terminated
}

model porep_market_deal_history {
  id                String            @id @default(uuid()) @db.Uuid
  porepMarketDealId String            @db.Uuid
  state             DealState
  createdAt         DateTime          @default(now())
  deal              porep_market_deal @relation(fields: [porepMarketDealId], references: [id])

  @@index([porepMarketDealId])
}

model porep_market_deal_requirement {
  id                String            @id @default(uuid()) @db.Uuid
  porepMarketDealId String            @unique @db.Uuid
  onChainDealId     BigInt            @unique // external deal ID - from chain
  retrievabilityBps BigInt
  bandwidthMbps     BigInt
  latencyMs         BigInt
  indexingPct       BigInt
  deal              porep_market_deal @relation(fields: [porepMarketDealId], references: [id])
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  @@index([porepMarketDealId])
}

model porep_market_deal_terms {
  id                     String            @id @default(uuid()) @db.Uuid
  porepMarketDealId      String            @unique @db.Uuid
  onChainDealId          BigInt            @unique // external deal ID - from chain
  dealSizeBytes          BigInt
  pricePerSectorPerMonth BigInt
  durationDays           Int
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt
  deal                   porep_market_deal @relation(fields: [porepMarketDealId], references: [id])
}

model porep_market_deal {
  id                       String                                 @id @default(uuid()) @db.Uuid
  onChainDealId            BigInt                                 @unique // external deal ID - from chain
  client                   String
  provider                 BigInt
  railId                   BigInt
  validatorContractAddress String
  state                    DealState
  terms                    porep_market_deal_terms?
  requirements             porep_market_deal_requirement?
  manifestLocation         String?
  allocationsRequiredCount BigInt?
  allocationsMatchedCount  BigInt?
  isAllocationsMatched     Boolean
  isRailTerminated         Boolean
  dealStartEpoch           BigInt?
  dealEndEpoch             BigInt?
  isDealEndEpochSetOnChain Boolean                                @default(false)
  allocationIds            BigInt[]
  history                  porep_market_deal_history[]
  settlement_history       porep_market_deal_settlement_history[]
  proposedAtBlock          BigInt
  modifyRailPaymentAt      DateTime?
  lastSyncedAt             DateTime                               @updatedAt
  createdAt                DateTime                               @default(now())
  updatedAt                DateTime                               @updatedAt

  @@index([onChainDealId])
  @@index([state])
  @@index([provider])
}

model porep_market_deal_settlement_history {
  id                String            @id @default(uuid()) @db.Uuid
  porepMarketDealId String            @db.Uuid
  epoch             BigInt
  settlementAt      DateTime          @default(now())
  deal              porep_market_deal @relation(fields: [porepMarketDealId], references: [id])

  @@index([porepMarketDealId])
}

model provider_score {
  id                String   @id @default(uuid()) @db.Uuid
  providerId        BigInt
  calculatedScore   BigInt
  retrievabilityBps BigInt
  bandwidthMbps     BigInt
  latencyMs         BigInt
  indexingPct       BigInt
  createdAt         DateTime @default(now())
}
